{
  "globalHeaders": {
    "Content-Security-Policy": "default-src 'self'; script-src 'self' https://analytics.manaiakalani.info; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data:; connect-src 'self' https://analytics.manaiakalani.info; object-src 'none'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'",
    "X-Content-Type-Options": "nosniff",
    "X-Frame-Options": "DENY",
    "Referrer-Policy": "strict-origin-when-cross-origin",
    "Permissions-Policy": "camera=(), microphone=(), geolocation=(), payment=()",
    "X-XSS-Protection": "0"
  },
  "responseOverrides": {
    "404": {
      "rewrite": "/404.html"
    }
  },
  "routes": [
    {
      "route": "/images/*",
      "headers": {
        "Cache-Control": "public, max-age=2592000, immutable"
      }
    },
    {
      "route": "/style.css",
      "headers": {
        "Cache-Control": "public, max-age=86400"
      }
    },
    {
      "route": "/script.js",
      "headers": {
        "Cache-Control": "public, max-age=86400"
      }
    },
    {
      "route": "/manifest.json",
      "headers": {
        "Cache-Control": "public, max-age=2592000, immutable"
      }
    },
    {
      "route": "/favicon.ico",
      "headers": {
        "Cache-Control": "public, max-age=2592000, immutable"
      }
    },
    {
      "route": "/apple-touch-icon.png",
      "headers": {
        "Cache-Control": "public, max-age=2592000, immutable"
      }
    }
  ]
}
